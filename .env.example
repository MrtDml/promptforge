# ============================================================
#  PromptForge — Root Environment Variables Example
#  Copy this file to .env and fill in real values.
#  NEVER commit the actual .env file to source control.
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=promptforge
POSTGRES_PASSWORD=supersecret_change_me
POSTGRES_DB=promptforge_db

# ─── Database connection (used by Prisma in the backend) ─────────────────────
# Local development: point to 127.0.0.1
# Docker Compose:    point to the service name "postgres"
DATABASE_URL=postgresql://promptforge:supersecret_change_me@127.0.0.1:5432/promptforge_db?schema=public

# ─── JSON Web Token ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Backend server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Must be prefixed NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── PgAdmin (optional Docker profile) ───────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@promptforge.dev
PGADMIN_DEFAULT_PASSWORD=pgadmin_secret
