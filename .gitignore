# =============================================================================
#  PromptForge — .gitignore
# =============================================================================

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
docker/.env
!.env.example
!docker/.env.example

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.yarn/
package-lock.json.bak

# ─── TypeScript build output ─────────────────────────────────────────────────
dist/
build/
*.js.map
*.d.ts.map

# ─── NestJS ──────────────────────────────────────────────────────────────────
backend/dist/
backend/coverage/
backend/.eslintcache

# ─── Next.js ─────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/coverage/
frontend/.eslintcache
# Next.js build output for standalone Docker image
frontend/.next/standalone/
frontend/.next/cache/

# ─── Prisma ──────────────────────────────────────────────────────────────────
# Generated client — regenerated via prisma generate
backend/node_modules/.prisma/
# Keep migrations in git; ignore local dev migration lock
backend/prisma/migrations/**/migration_lock.toml

# ─── Docker ──────────────────────────────────────────────────────────────────
# Local override files
docker-compose.override.yml
docker-compose.local.yml

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── IDE & Editors ───────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
junit.xml
test-results/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.tsbuildinfo
.cache/
tmp/
temp/
.claude/
n8n_backup/
