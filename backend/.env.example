# ── Uygulama ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Veritabanı ───────────────────────────────────────────────────────────────
# Railway: otomatik sağlanır (DATABASE_URL env değişkeni olarak gelir)
DATABASE_URL="postgresql://user:password@host:5432/promptforge?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# En az 32 karakter, production'da güçlü bir değer kullan
JWT_SECRET=guclu-ve-uzun-bir-secret-key-buraya-yaz-min-32-karakter
JWT_EXPIRES_IN=7d

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Production'da frontend URL'si (örn: https://promptforge.vercel.app)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── PayTR (Ödeme) ────────────────────────────────────────────────────────────
# https://www.paytr.com/merchant → Mağaza Bilgileri → API Bilgileri
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# test_mode=1: gerçek para çekilmez. Canlıya geçince 0 yap.
PAYTR_TEST_MODE=1

# ── URL'ler ───────────────────────────────────────────────────────────────────
# Backend'in dışarıdan erişilebilir URL'si
APP_URL=https://your-backend-domain.railway.app
# Frontend URL'si (ödeme sonrası yönlendirme için)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ── Railway Deploy (kullanıcı projeleri için) ─────────────────────────────────
# https://railway.app → Account Settings → API Tokens
RAILWAY_API_TOKEN=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OAuth — Google ───────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Authorized redirect URI: https://api.promptforgeai.dev/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ───────────────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: https://api.promptforgeai.dev/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Swagger ──────────────────────────────────────────────────────────────────
# Production'da Swagger'ı açmak için true yap (varsayılan: sadece development'ta açık)
SWAGGER_ENABLED=false
