# ── Uygulama ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Veritabanı ───────────────────────────────────────────────────────────────
# Railway: otomatik sağlanır (DATABASE_URL env değişkeni olarak gelir)
DATABASE_URL="postgresql://user:password@host:5432/promptforge?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# En az 32 karakter, production'da güçlü bir değer kullan
JWT_SECRET=guclu-ve-uzun-bir-secret-key-buraya-yaz-min-32-karakter
JWT_EXPIRES_IN=7d

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Production'da frontend URL'si (örn: https://promptforge.vercel.app)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── iyzico (Ödeme) ───────────────────────────────────────────────────────────
# https://merchant.iyzipay.com → Ayarlar → API Anahtarları
# Sandbox için: https://sandbox.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# setup-iyzico.js scripti çalıştırıldıktan sonra aşağıdakiler otomatik dolar
IYZICO_STARTER_PLAN_REF=
IYZICO_PRO_PLAN_REF=

# ── URL'ler ───────────────────────────────────────────────────────────────────
# Backend'in dışarıdan erişilebilir URL'si (iyzico callback için)
APP_URL=https://your-backend-domain.railway.app
# Frontend URL'si (ödeme sonrası yönlendirme için)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ── Railway Deploy (kullanıcı projeleri için) ─────────────────────────────────
# https://railway.app → Account Settings → API Tokens
RAILWAY_API_TOKEN=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
