# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=promptforge
POSTGRES_PASSWORD=supersecret_change_me
POSTGRES_DB=promptforge_db

# ─── Backend / Prisma ─────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL=postgresql://promptforge:supersecret_change_me@postgres:5432/promptforge_db?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── PgAdmin (optional, enable with --profile tools) ─────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@promptforge.dev
PGADMIN_DEFAULT_PASSWORD=pgadmin_secret
